{
  "IsEncrypted": false,
  "Host": {
    "CORS": "http://127.0.0.1:8080,http://localhost:8080",
    "CORSCredentials": false
  },
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "PYTHON_ISOLATE_WORKER_DEPENDENCIES": "1",

    "AZURE_AI_ENDPOINT": "https://<your-ai-foundry-endpoint>.openai.azure.com/",
    "AZURE_AI_DEPLOYMENT_NAME": "gpt-4o",
    "AZURE_AI_API_VERSION": "2024-02-01",
    "AZURE_AI_API_KEY": "<your-api-key-or-use-managed-identity>",
    "AZURE_AI_ENDPOINT_SECRET_NAME": "AzureAIEndpoint",
    "AZURE_AI_API_KEY_SECRET_NAME": "AzureAIApiKey",

    "COSMOS_DB_CONNECTION_STRING": "",
    "COSMOS_DB_ENDPOINT": "https://<your-cosmos-account>.documents.azure.com:443/",
    "COSMOS_DB_KEY": "<your-cosmos-key>",
    "COSMOS_DB_DATABASE": "antiscam",
    "COSMOS_DB_CONTAINER": "analyses",

    "AZURE_REDIS_CONNECTION_STRING": "<your-redis-name>.redis.cache.windows.net:6380,password=<your-key>,ssl=True,abortConnect=False",
    "TEAMS_WEBHOOK_URL": "<your-teams-incoming-webhook-url>",

    "AZURE_KEYVAULT_URL": "https://<your-keyvault-name>.vault.azure.net/",
    "STORAGE_ACCOUNT_CONNECTION_STRING": "DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net",

    "GOOGLE_SAFE_BROWSING_API_KEY": "<google-safe-browsing-api-key>",
    "URLHAUS_API_KEY": "<urlhaus-auth-key>"
  }
}
