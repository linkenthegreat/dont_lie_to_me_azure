@inject AppState State
@inject IJSRuntime JS

<div class="chat-input-area">
    @if (State.CurrentImages.Count > 0)
    {
        <div class="image-strip">
            @for (int i = 0; i < State.CurrentImages.Count; i++)
            {
                var index = i;
                <div class="image-thumb">
                    <img src="@State.CurrentImages[index]" alt="Attached @(index + 1)" />
                    <button class="thumb-remove"
                            @onclick="() => State.RemoveImage(index)"
                            type="button"
                            aria-label="Remove image">&times;</button>
                </div>
            }
        </div>
    }

    <div class="input-row">
        <InputFile OnChange="HandleFileSelected"
                   accept="image/*"
                   multiple
                   style="display:none"
                   id="chat-file-input" />

        <button class="btn-icon"
                @onclick="TriggerFileInput"
                disabled="@IsDisabled"
                type="button"
                aria-label="Attach image">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.5 12.5v3.75a1.25 1.25 0 01-1.25 1.25H3.75A1.25 1.25 0 012.5 16.25V12.5M14.375 6.25L10 1.875 5.625 6.25M10 1.875V12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <textarea @bind="_inputText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="Paste a message, URL, or ask..."
                  rows="1"
                  disabled="@IsDisabled"
                  class="chat-textarea"></textarea>

        <button class="btn-send @(CanSend ? "" : "btn-send--disabled")"
                @onclick="HandleSend"
                disabled="@(!CanSend)"
                type="button"
                aria-label="Send message">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.333 1.667L9.167 10.833M18.333 1.667l-5.833 16.666-3.333-7.5-7.5-3.333 16.666-5.833z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public bool IsDisabled { get; set; }

    private string _inputText = "";

    private bool CanSend => !IsDisabled && (!string.IsNullOrWhiteSpace(_inputText) || State.CurrentImages.Count > 0);

    private async Task HandleSend()
    {
        if (!CanSend) return;
        var text = _inputText;
        _inputText = "";
        await OnSend.InvokeAsync(text);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await HandleSend();
    }

    private async Task TriggerFileInput()
    {
        await JS.InvokeVoidAsync("triggerFileInput", "chat-file-input");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        const int maxFiles = 3;
        const long maxSize = 10 * 1024 * 1024;
        var remaining = maxFiles - State.CurrentImages.Count;
        if (remaining <= 0) return;

        foreach (var file in e.GetMultipleFiles(maxFiles).Take(remaining))
        {
            if (!file.ContentType.StartsWith("image/")) continue;
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var dataUri = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
                State.AddImage(dataUri);
            }
            catch { /* Skip files that fail */ }
        }
    }
}
