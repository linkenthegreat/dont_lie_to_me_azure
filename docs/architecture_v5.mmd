graph TD
    %% ══════════════════════════════════════════════════════════════
    %% Don't Lie To Me v5.0 – Blazor WASM + Agent Orchestration
    %% Chat-first unified UI · Blazor WebAssembly · Fluent UI
    %% Deterministic agent routing · Mobile-first PWA
    %% ══════════════════════════════════════════════════════════════

    User["👤 User<br/>Natural language<br/>Text · Images · URLs"] -->|"HTTPS"| SWA

    %% ════════════════════════════════════════
    %% HOSTING - Azure Static Web Apps
    %% ════════════════════════════════════════
    subgraph HostingLayer["Azure Static Web Apps"]
        SWA["Static Web Apps<br/>CDN · Auto SSL<br/>API Proxy → /api/*"]
    end

    SWA --> BlazorApp
    SWA -->|"/api/* proxy"| APILayer

    %% ════════════════════════════════════════
    %% FRONTEND - Blazor WebAssembly
    %% ════════════════════════════════════════
    subgraph FrontendLayer["Frontend — Blazor WebAssembly (.NET 8.0)"]
        BlazorApp["Blazor WASM Standalone<br/>PWA · Mobile-first<br/>Brand: #8A2BE2"]

        subgraph UIComponents["UI Components"]
            ChatPage["ChatPage.razor<br/>Unified chat interface<br/>No mode selection"]
            ChatPanel["ChatPanel.razor<br/>Message list + Input"]
            ChatInput["ChatInput.razor<br/>Text + Image upload<br/>Drag & Drop · Paste"]
            WelcomeMsg["WelcomeMessage.razor<br/>Hint cards<br/>Guided onboarding"]
            DataCard["DataCard.razor<br/>Polymorphic renderer<br/>Classification · URL<br/>Image · Sentiment"]
            TracePanel["TracePanel.razor<br/>Agent trace display<br/>Route path · Duration"]
        end

        subgraph FrontendServices["Services"]
            ApiClient["ApiClient.cs<br/>HttpClient → /api/chat<br/>JSON serialization"]
            AppState["AppState.cs<br/>Reactive state<br/>Conversation history<br/>Image queue"]
            SessionSvc["SessionService.cs<br/>LocalStorage<br/>Session persistence"]
        end

        subgraph Assets["Static Assets"]
            PWA["manifest.webmanifest<br/>Icons · Theme color<br/>short_name: Scam Detector"]
            SEO["index.html<br/>Open Graph · Twitter Cards<br/>JSON-LD · Favicon"]
            CSS["app.css<br/>Design system<br/>CSS custom properties<br/>Mobile-first responsive"]
            Interop["interop.js<br/>Clipboard paste<br/>Drag-drop · Auto-scroll"]
        end
    end

    ChatPage --> ChatPanel
    ChatPanel --> ChatInput
    ChatPanel --> WelcomeMsg
    ChatPanel --> DataCard
    ChatPanel --> TracePanel
    ApiClient -->|"POST /api/chat"| ChatEndpoint

    %% ════════════════════════════════════════
    %% BACKEND API - Azure Functions
    %% ════════════════════════════════════════
    subgraph APILayer["Azure Functions API Layer (Python 3.11)"]
        ChatEndpoint["POST /api/chat<br/>Conversational endpoint<br/>Routes via Orchestrator"]
        DirectEndpoints["Direct Endpoints<br/>/classify · /analyze<br/>/guidance · /sentiment<br/>/check-url · /analyze-image"]
        DataEndpoints["Data & Compliance<br/>/history · /export<br/>/feedback · /i18n<br/>/gdpr · /notify-teams"]
        HealthEndpoint["GET /api/health<br/>Liveness probe"]
    end

    ChatEndpoint --> OrchestratorAgent
    DirectEndpoints --> Services

    %% ════════════════════════════════════════
    %% AGENT RUNTIME - Orchestration Layer
    %% ════════════════════════════════════════
    subgraph AgentRuntime["Agent Runtime (Framework-Agnostic)"]

        OrchestratorAgent["🎯 Orchestrator Agent<br/>Deterministic routing<br/>Trace metadata<br/>Chain coordination"]

        subgraph ClassifierTeam["Classifier Team"]
            ReceptionistAgent["👋 Receptionist Agent<br/>Conversational empathy<br/>Context gathering"]
            ClassifierAgent["🔍 Classifier Agent<br/>SCAM · LIKELY_SCAM<br/>SUSPICIOUS · SAFE"]
        end

        subgraph AnalyzerTeam["Analyzer Team"]
            TextAnalyzerAgent["📝 Text Analyzer<br/>Red flags · Persuasion<br/>Impersonation patterns"]
            URLAnalyzerAgent["🔗 URL Analyzer<br/>Safe Browsing · URLhaus<br/>Threat intelligence"]
            ImageAnalyzerAgent["🖼️ Image Analyzer<br/>GPT-4o Vision<br/>Manipulation · Deepfake<br/>AI-generated detection"]
        end

        subgraph GuidanceTeam["Guidance Team"]
            ReportGeneratorAgent["📊 Report Generator<br/>Structured reports<br/>User-friendly output"]
            ResourceAssistantAgent["🏛️ Resource Assistant<br/>Location-aware<br/>Reporting agencies"]
        end

        RecordKeeperAgent["💾 Record Keeper<br/>Cosmos DB logging<br/>MCP tool exposure"]
    end

    OrchestratorAgent --> ReceptionistAgent
    OrchestratorAgent --> ClassifierAgent
    OrchestratorAgent --> TextAnalyzerAgent
    OrchestratorAgent --> URLAnalyzerAgent
    OrchestratorAgent --> ImageAnalyzerAgent
    OrchestratorAgent --> ReportGeneratorAgent
    OrchestratorAgent --> ResourceAssistantAgent
    OrchestratorAgent --> RecordKeeperAgent

    %% ════════════════════════════════════════
    %% SERVICE LAYER
    %% ════════════════════════════════════════
    subgraph ServiceLayer["Service Layer"]
        Services["Domain Services<br/>classify · analyze<br/>guidance · sentiment"]
        URLChecker["URL Checker<br/>Safe Browsing · URLhaus<br/>Metadata extraction"]
        ImageService["Image Service<br/>Pillow resize · EXIF<br/>GPT-4o Vision"]
        PromptLoader["Prompt Loader<br/>prompts.yaml<br/>Fallback pattern"]
    end

    ClassifierAgent --> Services
    TextAnalyzerAgent --> Services
    URLAnalyzerAgent --> URLChecker
    ImageAnalyzerAgent --> ImageService
    ReportGeneratorAgent --> Services
    Services --> PromptLoader

    %% ════════════════════════════════════════
    %% AI PROVIDER LAYER
    %% ════════════════════════════════════════
    subgraph AIProviderLayer["AI Provider Layer"]
        AIClient["ai_client.py<br/>Provider resolver<br/>chat(system, user, max, temp)"]
        GitHubProvider["GitHub Models<br/>Local dev · gpt-4o"]
        AzureProvider["Azure AI Foundry<br/>Production · Managed identity"]
        MockProvider["Mock Provider<br/>Local dev · No credentials"]
    end

    Services --> AIClient
    ImageService --> AIClient
    AIClient -->|"AI_PROVIDER=github"| GitHubProvider
    AIClient -->|"AI_PROVIDER=azure"| AzureProvider
    AIClient -->|"AI_PROVIDER=mock"| MockProvider

    %% ════════════════════════════════════════
    %% MCP TOOL INTEGRATION
    %% ════════════════════════════════════════
    subgraph MCPLayer["MCP Tool Layer"]
        MCPTools["MCP Tools<br/>store_analysis · query_history<br/>check_known_scam · url_check"]
    end

    RecordKeeperAgent --> MCPTools
    URLAnalyzerAgent --> MCPTools
    MCPTools --> CosmosDB

    %% ════════════════════════════════════════
    %% DATA LAYER
    %% ════════════════════════════════════════
    subgraph DataLayer["Data Layer"]
        CosmosDB["Azure Cosmos DB<br/>NoSQL · Session state<br/>Analysis history<br/>PK: /sessionId"]
        Redis["Azure Cache for Redis<br/>Response caching<br/>SHA-256 keys · 30min TTL"]
        BlobStorage["Azure Blob Storage<br/>Images · Screenshots"]
    end

    RecordKeeperAgent --> CosmosDB
    Services --> Redis
    Services --> BlobStorage

    %% ════════════════════════════════════════
    %% CROSS-CUTTING CONCERNS
    %% ════════════════════════════════════════
    subgraph CrossCutting["Cross-Cutting Concerns"]
        KeyVault["Azure Key Vault<br/>Secrets · Managed identity"]
        AppInsights["Application Insights<br/>Tracing · Metrics"]
    end

    AIClient -.->|"RBAC"| KeyVault
    APILayer -.->|"Telemetry"| AppInsights
    AgentRuntime -.->|"Traces"| AppInsights

    %% ════════════════════════════════════════
    %% ORCHESTRATOR ROUTING RULES
    %% ════════════════════════════════════════
    subgraph RoutingRules["Orchestrator Routing Rules"]
        GreetingRule["Greeting → Receptionist<br/>hello · hi · help"]
        URLRule["URL pattern → URL Analyzer<br/>http:// · https://"]
        ImageRule["Image input → Image Analyzer<br/>base64 · drag-drop · paste"]
        SuspiciousRule["Suspicious → Classifier<br/>→ Analyzer → Guidance"]
        ClarifyRule["Ambiguous → Receptionist<br/>Clarification needed"]
    end

    OrchestratorAgent -.->|"Routes"| RoutingRules

    %% ════════════════════════════════════════
    %% CI/CD
    %% ════════════════════════════════════════
    subgraph DevPlatform["CI/CD Pipeline"]
        Actions["GitHub Actions<br/>Backend: pytest<br/>Frontend: dotnet build<br/>Bicep deployment"]
    end

    Actions -.->|"Deploy"| HostingLayer
    Actions -.->|"Deploy"| APILayer

    %% ════════════════════════════════════════
    %% STYLES
    %% ════════════════════════════════════════
    classDef hosting fill:#0078d4,stroke:#005a9e,color:#fff
    classDef frontend fill:#8A2BE2,stroke:#6B1FB8,color:#fff
    classDef api fill:#0078d4,stroke:#005a9e,color:#fff
    classDef orchestrator fill:#6b3fa0,stroke:#4b2d73,color:#fff
    classDef classifier fill:#e3008c,stroke:#b4006c,color:#fff
    classDef analyzer fill:#00a36c,stroke:#007a50,color:#fff
    classDef guidance fill:#ff8c00,stroke:#cc7000,color:#fff
    classDef service fill:#107c10,stroke:#0b5a0b,color:#fff
    classDef ai fill:#9e9e9e,stroke:#757575,color:#fff
    classDef mcp fill:#d13438,stroke:#a52a2d,color:#fff
    classDef data fill:#004578,stroke:#003556,color:#fff
    classDef crosscut fill:#d83b01,stroke:#a52c00,color:#fff
    classDef dev fill:#2ea043,stroke:#238636,color:#fff

    class SWA hosting
    class BlazorApp,ChatPage,ChatPanel,ChatInput,WelcomeMsg,DataCard,TracePanel,ApiClient,AppState,SessionSvc,PWA,SEO,CSS,Interop frontend
    class ChatEndpoint,DirectEndpoints,DataEndpoints,HealthEndpoint api
    class OrchestratorAgent orchestrator
    class ReceptionistAgent,ClassifierAgent classifier
    class TextAnalyzerAgent,URLAnalyzerAgent,ImageAnalyzerAgent analyzer
    class ReportGeneratorAgent,ResourceAssistantAgent guidance
    class RecordKeeperAgent mcp
    class Services,URLChecker,ImageService,PromptLoader service
    class AIClient,GitHubProvider,AzureProvider,MockProvider ai
    class MCPTools mcp
    class CosmosDB,Redis,BlobStorage data
    class KeyVault,AppInsights crosscut
    class Actions dev
    class GreetingRule,URLRule,ImageRule,SuspiciousRule,ClarifyRule orchestrator
