graph TD
    %% ══════════════════════════════════════════════════════════════
    %% Don't Lie To Me v3.0 – Service Layer + Centralized Prompts
    %% Multi-provider AI · YAML Prompt Management · Thin Adapters
    %% Microsoft Foundry · Azure Services · Local Development
    %% ══════════════════════════════════════════════════════════════

    User["👤 User"] -->|"HTTPS"| SWA

    %% ════════════════════════════════════════
    %% FRONTEND
    %% ════════════════════════════════════════
    SWA["Azure Static Web Apps<br/>Frontend · CDN · Auto SSL<br/>Staging per PR"]
    SWA -->|"API proxy"| FuncApp

    %% ════════════════════════════════════════
    %% BACKEND API – THIN ADAPTER LAYER
    %% ════════════════════════════════════════
    subgraph Compute["Azure Functions – Python 3.11"]
        FuncApp["HTTP Endpoints (Thin Adapters)<br/>/classify · /analyze<br/>/guidance · /health<br/>━━━━━━━━━━━━<br/>Validate → Invoke → Serialize"]
    end

    FuncApp -->|"Delegates to"| ServiceLayer

    %% ════════════════════════════════════════
    %% SERVICE LAYER – BUSINESS LOGIC
    %% ════════════════════════════════════════
    subgraph ServiceLayer["Service Layer (Core Business Logic)"]
        ScamClassifier["scam_classifier.py<br/>Classification + confidence"]
        MessageAnalyzer["message_analyzer.py<br/>Red flags · Persuasion<br/>Impersonation detection"]
        GuidanceGenerator["guidance_generator.py<br/>Safety · Reporting<br/>Prevention tips"]
    end

    %% ════════════════════════════════════════
    %% PROMPT MANAGEMENT
    %% ════════════════════════════════════════
    subgraph PromptSystem["Centralized Prompt Management"]
        PromptsYAML["prompts.yaml<br/>━━━━━━━━━━━━<br/>System prompts<br/>Model preferences<br/>Temperature · Max tokens<br/>Description"]
        PromptsLoader["shared/prompts.py<br/>━━━━━━━━━━━━<br/>get_prompt_config()<br/>Lazy load at import<br/>↓ Fallback to embedded"]
        FallbackPrompts["Embedded Constants<br/>━━━━━━━━━━━━<br/>_FALLBACK_SYSTEM_PROMPT<br/>in each service module"]
    end

    PromptsYAML -->|"Load at startup"| PromptsLoader
    PromptsLoader -.->|"YAML missing/invalid"| FallbackPrompts
    PromptsLoader -->|"Loaded successfully"| ScamClassifier
    PromptsLoader -->|"Loaded successfully"| MessageAnalyzer
    PromptsLoader -->|"Loaded successfully"| GuidanceGenerator
    FallbackPrompts -.->|"Fallback"| ScamClassifier
    FallbackPrompts -.->|"Fallback"| MessageAnalyzer
    FallbackPrompts -.->|"Fallback"| GuidanceGenerator

    %% ════════════════════════════════════════
    %% MULTI-PROVIDER AI CLIENT
    %% ════════════════════════════════════════
    subgraph AIClient["Multi-Provider AI Client"]
        ClientFactory["AzureAIClient(provider=...)<br/>━━━━━━━━━━━━<br/>Unified chat() interface"]
        AzureProvider["Azure AI Foundry<br/>Production · Managed Identity"]
        GitHubProvider["GitHub Models<br/>Local dev · PAT auth"]
        MockProvider["Mock Client<br/>Testing · Canned responses"]
    end

    ScamClassifier -->|"chat(system_prompt, user_message)"| ClientFactory
    MessageAnalyzer -->|"chat(system_prompt, user_message)"| ClientFactory
    GuidanceGenerator -->|"chat(system_prompt, user_message)"| ClientFactory

    ClientFactory -->|"AI_PROVIDER=azure"| AzureProvider
    ClientFactory -->|"AI_PROVIDER=github"| GitHubProvider
    ClientFactory -->|"AI_PROVIDER=mock"| MockProvider

    %% ════════════════════════════════════════
    %% FOUNDRY MODELS (Production)
    %% ════════════════════════════════════════
    subgraph Foundry["Microsoft Foundry (Production)"]
        GPT4o["GPT-4o<br/>Deep analysis · Guidance"]
        GPT4oMini["GPT-4o mini<br/>Fast classification"]
    end

    AzureProvider --> GPT4o
    AzureProvider --> GPT4oMini

    %% ════════════════════════════════════════
    %% GITHUB MODELS (Local Dev)
    %% ════════════════════════════════════════
    subgraph GitHubModels["GitHub Models (Local Dev)"]
        GitHubGPT["models.github.ai<br/>gpt-4o · gpt-4o-mini<br/>Free · No Azure credentials"]
    end

    GitHubProvider --> GitHubGPT

    %% ════════════════════════════════════════
    %% AZURE MCP (Future Phase)
    %% ════════════════════════════════════════
    subgraph MCP["Azure MCP Server (Phase F)"]
        MCPServer["MCP Tools Interface"]
        ToolStore["store_analysis"]
        ToolQuery["query_history"]
        ToolScam["check_known_scam"]
    end

    ServiceLayer -.->|"Future: Tool calls"| MCPServer
    MCPServer --> ToolStore
    MCPServer --> ToolQuery
    MCPServer --> ToolScam

    %% ════════════════════════════════════════
    %% DATA LAYER
    %% ════════════════════════════════════════
    subgraph Data["Data Layer"]
        CosmosDB["Azure Cosmos DB<br/>NoSQL · PK: /sessionId"]
        BlobStorage["Azure Blob Storage<br/>Images · Logs"]
    end

    ToolStore -->|"Upsert"| CosmosDB
    ToolQuery -->|"Query"| CosmosDB
    ToolScam -->|"Query"| CosmosDB
    FuncApp -->|"Store images"| BlobStorage

    %% ════════════════════════════════════════
    %% CROSS-CUTTING CONCERNS
    %% ════════════════════════════════════════
    KeyVault["Azure Key Vault<br/>Secrets · Managed Identity"]
    AppInsights["Application Insights<br/>Tracing · Metrics · Alerts"]

    FuncApp -.->|"RBAC"| KeyVault
    FuncApp -.->|"Telemetry"| AppInsights
    ServiceLayer -.->|"Logging"| AppInsights

    %% ════════════════════════════════════════
    %% CI/CD & DEVELOPMENT
    %% ════════════════════════════════════════
    subgraph DevPlatform["Developer Platform"]
        Copilot["GitHub Copilot<br/>Code gen · PR reviews"]
        Actions["GitHub Actions<br/>Build · Test · Deploy<br/>Bicep IaC validation"]
    end

    Copilot -.->|"Assists"| Actions
    Actions -.->|"Deploy"| SWA
    Actions -.->|"Deploy"| Compute

    %% ════════════════════════════════════════
    %% LEGEND
    %% ════════════════════════════════════════
    subgraph Legend["Architecture Patterns (v3.0)"]
        L1["━━ Thin Adapter Pattern: HTTP/MCP layers only validate/invoke/serialize"]
        L2["━━ Service Layer Pattern: Business logic is reusable across channels"]
        L3["━━ Centralized Prompts: YAML config with embedded fallbacks"]
        L4["━━ Multi-Provider AI: Switch between Azure/GitHub/Mock via env var"]
        L5["━━ Dependency Injection: Services accept optional client for testing"]
    end
